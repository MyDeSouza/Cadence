# Database
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/cadence"

# Server
PORT=3001
NODE_ENV=development

# Google OAuth (Step 6 — Google Calendar adapter)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/sync/google/callback

NOTION_TOKEN=your_notion_integration_token
YOUTUBE_API_KEY=your_youtube_data_api_key
YOUTUBE_CHANNEL_IDS=UCxxxxxx,UCyyyyyy   # optional: comma-separated channel IDs for latest-video mode